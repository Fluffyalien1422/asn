{
  "$schema": "https://raw.githubusercontent.com/Bedrock-OSS/regolith-schemas/main/config/v1.4.json",
  "author": "Fluffyalien1422",
  "name": "Advanced Storage Network",
  "packs": {
    "behaviorPack": "./packs/BP",
    "resourcePack": "./packs/RP"
  },
  "regolith": {
    "formatVersion": "1.4.0",
    "dataPath": "./packs/data",
    "filterDefinitions": {
      "simple_manifest": {
        "runWith": "shell",
        "command": "npm run tsx ./scripts/filters/simple_manifest"
      },
      "build_scripts": {
        "runWith": "shell",
        "command": "npx esbuild ./BP/scripts/index.ts --outfile=./BP/scripts/__bundle.js --bundle --format=esm --log-level=warning --external:@minecraft/server --external:@minecraft/server-ui --preserve-symlinks"
      },
      "minify_and_clean_scripts": {
        "runWith": "shell",
        "command": "npx terser ./BP/scripts/__bundle.js --module -cmo ./BP/scripts/__bundle.js; Remove-Item ./BP/scripts/* -Recurse -Exclude __bundle.js"
      },
      "gen_page_number_items": {
        "runWith": "shell",
        "command": "npm run tsx ./scripts/filters/page_number_items"
      }
    },
    "profiles": {
      "default": {
        "export": {
          "target": "development",
          "build": "standard"
        },
        "filters": [
          {
            "filter": "simple_manifest"
          },
          {
            "filter": "build_scripts"
          },
          {
            "filter": "gen_page_number_items"
          }
        ]
      },
      "prod": {
        "export": {
          "target": "local"
        },
        "filters": [
          {
            "profile": "default"
          },
          {
            "filter": "minify_and_clean_scripts"
          }
        ]
      }
    }
  }
}
