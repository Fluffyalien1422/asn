{
  "$schema": "https://raw.githubusercontent.com/Bedrock-OSS/regolith-schemas/main/config/v1.2.json",
  "author": "Fluffyalien1422",
  "name": "Advanced Storage Network",
  "packs": {
    "behaviorPack": "./packs/BP",
    "resourcePack": "./packs/RP"
  },
  "regolith": {
    "dataPath": "./packs/data",
    "filterDefinitions": {
      "simple_manifest": {
        "runWith": "shell",
        "command": "npm run tsx ./scripts/filters/simple_manifest"
      },
      "build_scripts": {
        "runWith": "shell",
        "command": "npx esbuild ./BP/scripts/index.ts --outfile=./BP/scripts/__bundle.js --bundle --format=esm --external:@minecraft/server --external:@minecraft/server-ui"
      },
      "minify_and_clean_scripts": {
        "runWith": "shell",
        "command": "npx terser ./BP/scripts/__bundle.js --module -cmo ./BP/scripts/__bundle.js; Remove-Item ./BP/scripts/* -Recurse -Exclude __bundle.js"
      }
    },
    "profiles": {
      "default": {
        "export": {
          "target": "development"
        },
        "filters": [
          {
            "filter": "simple_manifest"
          },
          {
            "filter": "build_scripts"
          }
        ]
      },
      "prod": {
        "export": {
          "target": "local"
        },
        "filters": [
          {
            "profile": "default"
          },
          {
            "filter": "minify_and_clean_scripts"
          }
        ]
      }
    }
  }
}
