{
  "format_version": "1.26.0",
  "minecraft:block": {
    "description": {
      "identifier": "fluffyalien_asn:level_emitter",
      "menu_category": {
        "category": "items"
      },
      "traits": {
        "minecraft:placement_direction": {
          "enabled_states": ["minecraft:cardinal_direction"]
        }
      },
      "states": {
        "fluffyalien_asn:lit": [0, 1],
        "fluffyalien_asn:east": [false, true],
        "fluffyalien_asn:south": [false, true],
        "fluffyalien_asn:west": [false, true],
        "fluffyalien_asn:up": [false, true],
        "fluffyalien_asn:down": [false, true]
      }
    },
    "components": {
      "fluffyalien_asn:network_device": {},
      "fluffyalien_asn:level_emitter": {},
      "tag:fluffyalien_asn:storage_network_connectable": {},

      "minecraft:geometry": {
        "identifier": "geometry.fluffyalien_asn.level_emitter",
        "bone_visibility": {
          "south": "q.block_state('fluffyalien_asn:south')",
          "east": "q.block_state('fluffyalien_asn:east')",
          "west": "q.block_state('fluffyalien_asn:west')",
          "up": "q.block_state('fluffyalien_asn:up')",
          "down": "q.block_state('fluffyalien_asn:down')"
        }
      },
      "minecraft:collision_box": {
        "origin": [-4, 4, -8],
        "size": [8, 8, 12]
      },
      "minecraft:selection_box": {
        "origin": [-3, 5, -8],
        "size": [6, 6, 11]
      },
      "minecraft:light_dampening": 0,
      "minecraft:destructible_by_explosion": false,
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 1
      },
      "minecraft:movable": {
        "movement_type": "immovable"
      },
      "minecraft:tick": {
        "interval_range": [5, 5]
      }
    },
    "permutations": [
      {
        "condition": "!q.block_state('fluffyalien_asn:lit')",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "render_method": "alpha_test",
              "texture": "fluffyalien_asn:level_emitter_off"
            }
          }
        }
      },
      {
        "condition": "q.block_state('fluffyalien_asn:lit')",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "fluffyalien_asn:level_emitter_on"
            }
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 180, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 90, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, -90, 0]
          }
        }
      }
    ]
  }
}
