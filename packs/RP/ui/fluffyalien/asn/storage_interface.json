        }
      },
      {
        "back_btn_slot@fluffyalien_asn:storage_interface.item_slot": {
          "$index": 28,
          "offset": [36, 8]
        }
      },
      {
        "page_num_digit1_slot@fluffyalien_asn:storage_interface.item_slot": {
